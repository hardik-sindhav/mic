# Backend Environment Variables
# GitHub Actions requires these as secrets
# See: Settings → Secrets and variables → Actions

# Database
DATABASE_URL=mongodb+srv://user:password@cluster.mongodb.net/database?retryWrites=true&w=majority

# JWT
JWT_SECRET=your-super-secret-jwt-key-here-min-32-chars-recommended

# Server
NODE_ENV=production
PORT=5000

# CORS
CORS_ORIGIN=http://localhost:3000

# Logging
LOG_LEVEL=info

# Optional: Admin Bootstrap (first admin user)
# ADMIN_EMAIL=admin@example.com
# ADMIN_PASSWORD=SecurePassword123

# Optional: Rate Limiting
RATE_LIMIT_WINDOW=900000
RATE_LIMIT_MAX_REQUESTS=100

# Optional: Email Service (if needed)
# SMTP_HOST=
# SMTP_PORT=
# SMTP_USER=
# SMTP_PASS=

# Optional: File Upload
# MAX_FILE_SIZE=5242880
# UPLOAD_DIR=./uploads
